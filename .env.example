# Required
DATABASE_URL=postgresql://user:password@localhost:5432/replyhandler
GEMINI_API_KEY=your-gemini-api-key
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Lead enrichment
LEADMAGIC_API_KEY=your-leadmagic-api-key

# Cal.com (used for booking confirmation — the API itself is public, but set this if needed)
CALCOM_API_KEY=your-calcom-api-key

# Admin API credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Server
PORT=3000

# Railway sets this automatically — used to construct webhook URLs
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
