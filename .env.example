# ─── AI Classification ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Slack ────────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Optional: POST /admin/test/slack-draft/:clientId with header x-webhook-test-secret
WEBHOOK_TEST_SECRET=long-random-string-for-local-slack-testing

# Optional: IANA timezone for displaying verified slot labels (default America/New_York)
# DEFAULT_BOOKING_TIMEZONE=America/Los_Angeles

# Hours after your outbound message (Slack-approved send) to nudge in Slack if prospect hasn't replied
# FOLLOW_UP_REMINDER_HOURS=24

# ─── Lead Enrichment (Lead Magic) ────────────────────────────────────
LEADMAGIC_API_KEY=your-leadmagic-api-key

# ─── Google Calendar OAuth (console.cloud.google.com) ────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Microsoft / Outlook OAuth (portal.azure.com) ────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret

# ─── Server ───────────────────────────────────────────────────────────
# PORT and RAILWAY_PUBLIC_DOMAIN are set automatically by Railway.
# DATABASE_URL is injected by the Postgres plugin — do NOT set manually.
#
# On boot: apply-schema-to-db.js (empty DB only), then run-migrations.js (002–010, schema_migrations). Skip with:
# SKIP_DB_MIGRATIONS=1
#
# Optional: if set (e.g. 1), boot and GET /health fail until that many active clients exist. Use after first client is created.
# MIN_ACTIVE_CLIENTS=1

# ─── SmartLead ────────────────────────────────────────────────────────
# Convert plain-text Slack replies to minimal HTML for SmartLead (links + line breaks). Set to 0 to send plain text only.
# SMARTLEAD_OUTBOUND_HTML=1
#
# Inbound webhook: skip non-reply events, parse HTML/plain from payload, reconcile duplicate REPLY rows via message-history. Set to 0 for legacy behavior.
# SMARTLEAD_WEBHOOK_ENHANCEMENTS=1

# ─── HeyReach polling backstop ───────────────────────────────────────
# Webhooks are primary. This polling backstop scans recent conversations to recover delayed/missed HeyReach replies.
# HEYREACH_POLL_ENABLED=1
# HEYREACH_POLL_MINUTES=3
# HEYREACH_POLL_LOOKBACK_HOURS=8
# HEYREACH_POLL_MAX_CONVERSATIONS=100
# Optional: comma-separated LinkedIn account IDs to limit the poller.
# HEYREACH_POLL_ACCOUNT_IDS=12345,67890
#
# Normally client-level API keys/slack routing live in the clients table.
# Temporary fallback if DB clients are not restored yet:
# HEYREACH_POLL_CLIENTS_JSON=[{"id":"salesglider","name":"SalesGlider","heyreach_api_key":"...","slack_bot_token":"xoxb-...","slack_channel_id":"C...","booking_link":"https://...","voice_prompt":"..."}]
